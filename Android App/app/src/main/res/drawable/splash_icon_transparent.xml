<?xml version="1.0" encoding="utf-8"?>
<!--
    Transparent placeholder used as the Android 12+ system splash icon.
    We want the OS splash to be a plain white screen that seamlessly hands
    off to our Composable SplashScreen (which draws its own animated FICA
    logo and Vodafone branding) — showing the launcher icon here would
    create a double-splash effect.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <size android:width="1dp" android:height="1dp" />
</shape>
